{
  "dashboard": {
    "title": "MLOps Cost Monitoring",
    "tags": ["cost", "mlops", "kubernetes"],
    "timezone": "UTC",
    "panels": [
      {
        "id": 1,
        "title": "Estimated Daily Cost by Namespace",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum by (namespace) (\n  (\n    kube_pod_container_resource_requests{resource=\"cpu\"} * 0.0416\n  ) + (\n    kube_pod_container_resource_requests{resource=\"memory\"} / (1024 * 1024 * 1024) * 0.00405\n  )\n)",
            "legendFormat": "{{namespace}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "min": 0,
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "smooth",
              "pointSize": 5,
              "showPoints": "auto",
              "spanNulls": false,
              "stacking": { "mode": "normal", "group": "A" }
            }
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "Total Estimated Daily Cluster Cost",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(\n  (kube_pod_container_resource_requests{resource=\"cpu\"} * 0.0416) +\n  (kube_pod_container_resource_requests{resource=\"memory\"} / (1024 * 1024 * 1024) * 0.00405)\n)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "min": 0
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
      },
      {
        "id": 3,
        "title": "Top 10 Expensive Pods (CPU cost)",
        "type": "bargauge",
        "targets": [
          {
            "expr": "topk(10, sum by (pod, namespace) (kube_pod_container_resource_requests{resource=\"cpu\"} * 0.0416))",
            "legendFormat": "{{namespace}}/{{pod}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 20 },
                { "color": "red", "value": 50 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
      },
      {
        "id": 4,
        "title": "Top 10 Expensive Pods (Memory cost)",
        "type": "bargauge",
        "targets": [
          {
            "expr": "topk(10, sum by (pod, namespace) (kube_pod_container_resource_requests{resource=\"memory\"} / (1024 * 1024 * 1024) * 0.00405))",
            "legendFormat": "{{namespace}}/{{pod}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "min": 0,
            "max": 50,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 30 }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
      },
      {
        "id": 5,
        "title": "Cost per Experiment / Run (MLflow)",
        "type": "table",
        "description": "Correlates MLflow run durations with average resource usage to estimate experiment cost.",
        "targets": [
          {
            "expr": "avg_over_time(\n  sum by (namespace) (\n    (kube_pod_container_resource_requests{resource=\"cpu\"} * 0.0416) +\n    (kube_pod_container_resource_requests{resource=\"memory\"} / (1024*1024*1024) * 0.00405)\n  )[1h:5m]\n)",
            "format": "table",
            "refId": "A"
          }
        ],
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 }
      }
    ],
    "time": { "from": "now-6h", "to": "now" },
    "refresh": "30s",
    "schemaVersion": 36,
    "version": 1
  }
}
